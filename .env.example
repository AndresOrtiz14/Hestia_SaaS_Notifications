# ── Hestia Backend ──────────────────────────────────────────────────────────────
HESTIA_API_URL=http://localhost:3000/api/v1
HESTIA_API_KEY=your-internal-api-key

# ── Worker ───────────────────────────────────────────────────────────────────────
POLLING_INTERVAL_SECONDS=10          # Frecuencia del worker de polling
FAQ_SURVEY_DELAY_SECONDS=30          # Delay antes de enviar encuesta FAQ (manejado por scheduledAt en backend)

# ── Servidor ─────────────────────────────────────────────────────────────────────
PORT=4000
WEBHOOK_SECRET=your-webhook-secret   # Secret para verificar llamadas desde el bot principal

# ── WhatsApp Cloud API ──────────────────────────────────
# Per-tenant credentials (phone_id, token) come from the Property in DB.
# Only the verify_token is global (Meta webhook handshake).
WHATSAPP_VERIFY_TOKEN=your_verify_token
